generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DRIVER
  HOSPITAL
  ADMIN
}

enum RequestStatus {
  PENDING
  ACCEPTED
  EN_ROUTE
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestsAsPatient Request[] @relation("PatientRequests")
  requestsAsDriver  Request[] @relation("DriverRequests")
  ambulance         Ambulance?
  hospital          Hospital?
}

model Ambulance {
  id           String   @id @default(uuid())
  driverId     String   @unique
  driver       User     @relation(fields: [driverId], references: [id])
  plateNumber  String
  locationLat  Float?
  locationLng  Float?
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Hospital {
  id           String   @id @default(uuid())
  adminId      String   @unique
  admin        User     @relation(fields: [adminId], references: [id])
  name         String
  address      String
  locationLat  Float?
  locationLng  Float?
  bedCapacity  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Request {
  id           String        @id @default(uuid())
  patientId    String
  patient      User          @relation("PatientRequests", fields: [patientId], references: [id])
  driverId     String?
  driver       User?         @relation("DriverRequests", fields: [driverId], references: [id])
  status       RequestStatus @default(PENDING)
  locationLat  Float
  locationLng  Float
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}
