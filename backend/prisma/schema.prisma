generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(uuid())
  name              String
  email             String     @unique
  password          String
  phone             String?
  hospitalId        String?
  role              Role       @default(PATIENT)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  trustScore        Int        @default(0)
  isBlacklisted     Boolean    @default(false)
  ambulance         Ambulance? @relation("DriverAmbulance")
  hospital          Hospital?  @relation("HospitalStaff", fields: [hospitalId], references: [id])
  requestsAsDriver  Request[]  @relation("DriverRequests")
  requestsAsPatient Request[]  @relation("PatientRequests")
}

model Ambulance {
  id          String    @id @default(uuid())
  driverId    String?   @unique
  hospitalId  String
  plateNumber String
  locationLat Float?
  locationLng Float?
  isAvailable Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  driver      User?     @relation("DriverAmbulance", fields: [driverId], references: [id])
  hospital    Hospital  @relation("HospitalAmbulances", fields: [hospitalId], references: [id], onDelete: Cascade)
  request     Request[] @relation("RequestAmbulance")
}

model Hospital {
  id                   String      @id @default(uuid())
  name                 String
  address              String?
  locationLat          Float?
  locationLng          Float?
  bedCapacity          Int         @default(0)
  icuBedsAvailable     Int         @default(0)
  generalBedsAvailable Int         @default(0)
  ventilatorsAvailable Int         @default(0)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  ambulances           Ambulance[] @relation("HospitalAmbulances")
  staff                User[]      @relation("HospitalStaff")
}

model Request {
  id            String        @id @default(uuid())
  patientId     String?
  driverId      String?
  status        RequestStatus @default(PENDING)
  locationLat   Float
  locationLng   Float
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  ambulanceId   String?
  emergencyType String
  medicalNotes  String?
  patientName   String        @default("Anonymous")
  patientPhone  String?
  pickupAddress String
  
  // ML Fields & External API Context
  distanceKm          Float?
  trafficLevel        String?
  weather             String?
  mlDelayRisk         String?
  mlExpectedDelay     Float?
  mlReasons           String?   // JSON Stringified
  mlSuggestedActions  String?   // JSON Stringified

  // Anti-Spam / Guest Flow Additions
  isGuest           Boolean   @default(false)
  guestSessionId    String?
  ipAddress         String?
  userAgent         String?
  deviceId          String?
  isSuspicious      Boolean   @default(false)
  suspiciousReason  String?
  trustScoreAtRequest Int?
  isFake            Boolean   @default(false)
  driverFeedback    String?

  ambulance     Ambulance?    @relation("RequestAmbulance", fields: [ambulanceId], references: [id])
  driver        User?         @relation("DriverRequests", fields: [driverId], references: [id])
  patient       User?         @relation("PatientRequests", fields: [patientId], references: [id], onDelete: Cascade)
}

model DeviceTrust {
  deviceId      String   @id
  trustScore    Int      @default(0)
  totalFake     Int      @default(0)
  totalValid    Int      @default(0)
  isBlacklisted Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum Role {
  PATIENT
  DRIVER
  HOSPITAL
  ADMIN
}

enum RequestStatus {
  PENDING
  ACCEPTED
  EN_ROUTE
  ARRIVED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}
