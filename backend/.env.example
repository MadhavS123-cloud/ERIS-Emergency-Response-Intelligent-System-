# Server
PORT=5001
NODE_ENV=production

# Database (Render PostgreSQL - use Internal DB URL)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT Auth
JWT_SECRET="your-long-random-secret-here"
JWT_EXPIRES_IN="1d"

# Redis (Render Redis - use Internal Redis URL)
REDIS_URL="redis://default:password@host:6379"

# CORS - set this to your Vercel frontend URL
CORS_ORIGIN="https://your-app.vercel.app"

# ML Service (Render - add after deploying ML service)
ML_SERVICE_URL="https://your-ml-service.onrender.com"

# External APIs (optional - falls back to mocked values if not set)
GOOGLE_MAPS_API_KEY=""
WEATHER_API_KEY=""
